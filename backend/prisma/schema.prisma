generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trips Trip[]
}

model Trip {
  id          String   @id @default(cuid())
  userId      String
  title       String
  destination String
  startDate   DateTime
  endDate     DateTime
  coverImage  String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  days Day[]

  @@index([userId])
}

model Day {
  id     String   @id @default(cuid())
  tripId String
  date   DateTime
  order  Int

  trip       Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@unique([tripId, date])
  @@index([tripId])
}

model Activity {
  id      String  @id @default(cuid())
  dayId   String
  title   String
  time    String? 
  lat     Float?
  lng     Float?
  address String?
  notes   String?
  cost    Float?
  order   Int

  day Day @relation(fields: [dayId], references: [id], onDelete: Cascade)

  @@index([dayId])
}