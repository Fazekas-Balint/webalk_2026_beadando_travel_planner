# Server
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# Database
DATABASE_URL="file:./dev.db"
# Production: postgresql://user:pass@host:5432/dbname

# JWT
JWT_ACCESS_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-different-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookie
COOKIE_DOMAIN=localhost

# External APIs
NOMINATIM_USER_AGENT="TripPlanner/1.0 (contact@example.com)"
